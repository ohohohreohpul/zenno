# Public DNS name pointed at the gateway server (A/AAAA record).
GATEWAY_DOMAIN=wa.example.com

# Zenno production URL. Used as the only allowed browser origin.
ZENNO_APP_URL=https://zen-agent.vercel.app

# Generate both secrets independently, for example:
#   openssl rand -hex 32
EVOLUTION_API_KEY=replace-with-a-random-64-character-secret
POSTGRES_PASSWORD=replace-with-a-different-random-secret

POSTGRES_DB=evolution
POSTGRES_USER=evolution

# Optional residential/ISP proxy for WhatsApp session traffic. DMChamp uses
# managed proxies for this layer. Leave blank for the first controlled test;
# configure a reputable proxy before operating many customer sessions.
PROXY_HOST=
PROXY_PORT=
PROXY_PROTOCOL=http
PROXY_USERNAME=
PROXY_PASSWORD=
