# Local demo: set true. Production: set false and configure Supabase below.
MOCK_MODE=true
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# At least one AI provider is required for intelligent replies.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4
ANTHROPIC_API_KEY=

# Required in production. Generate with: openssl rand -base64 48
AUTH_SECRET=
PUBLIC_APP_URL=http://localhost:3000

# WhatsApp session gateway (Evolution-compatible)
WA_GATEWAY_URL=
WA_GATEWAY_API_KEY=
WA_GATEWAY_WEBHOOK_TOKEN=

# Optional provider/channel fallbacks
WHATSAPP_API_KEY=
WHATSAPP_API_URL=
WHATSAPP_WEBHOOK_SECRET=
META_PAGE_ACCESS_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
MESSENGER_VERIFY_TOKEN=

# Optional billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
