# Local isolated mode: set true. Production must use false.
MOCK_MODE=false
NEXT_PUBLIC_SUPABASE_URL=
# Preferred when available. Keep server-only.
SUPABASE_SERVICE_ROLE_KEY=
# Supported server-only alternative when paired with AUTH_SECRET and the checked-in RLS policies.
SUPABASE_PUBLISHABLE_KEY=

# Only used when MOCK_MODE=true locally.
LOCAL_ADMIN_EMAIL=owner@zenno.local
LOCAL_ADMIN_PASSWORD=change-me-locally

# At least one AI provider is required for intelligent replies.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=z-ai/glm-4.5-air
ANTHROPIC_API_KEY=

# Required in production. Generate with: openssl rand -base64 48
AUTH_SECRET=
PUBLIC_APP_URL=http://localhost:3000

# WhatsApp session gateway (Evolution-compatible)
WA_GATEWAY_URL=
WA_GATEWAY_API_KEY=
WA_GATEWAY_WEBHOOK_TOKEN=

# Meta one-click OAuth (Connect with Facebook for Messenger + Instagram).
# Callback to register on the Meta app: <PUBLIC_APP_URL>/api/channels/meta/oauth/callback
META_APP_ID=

# Optional provider/channel fallbacks
WHATSAPP_API_KEY=
WHATSAPP_API_URL=
WHATSAPP_WEBHOOK_SECRET=
META_PAGE_ACCESS_TOKEN=
META_APP_SECRET=
ZERNIO_API_KEY=
ZERNIO_WEBHOOK_SECRET=
META_VERIFY_TOKEN=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
MESSENGER_VERIFY_TOKEN=

# Optional billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
